	url = {https://linkinghub.elsevier.com/retrieve/pii/S0165168422000275},
	doi = {10.1016/j.sigpro.2022.108480},
	abstract = {We consider the problem of signal interpolation on graphs, i.e. recovering one or multiple graph signal values from incomplete measurements. We propose a review of the graph signal interpolation methods, which enlightens the restrictive underlying hypothesis of signal smoothness over the graph. We formulate a new interpolation framework based on a locality criterion designed to handle non-smooth signals, and provide corresponding speciﬁc solutions. We validate the proposed methods on synthetic and real-world interpolation problems, and analyse the stability of our methods regarding the interpolation problem main parameters.},
