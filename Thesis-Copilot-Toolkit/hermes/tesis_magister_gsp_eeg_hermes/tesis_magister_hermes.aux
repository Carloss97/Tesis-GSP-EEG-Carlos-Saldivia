\@writefile{lof}{\contentsline {figure}{\numberline {6.4}{\ignorespaces Curva de degradación SNR para BCI IV 2a (modo \textit  {random}). TRSS mantiene un SNR aceptable ($> 25$~dB) incluso con un 40\% de canales perdidos, mientras que las splines caen por debajo de 15~dB.}}{47}{figure.caption.21}\protected@file@percent }
\newlabel{fig:degradation_bci_random}{{6.4}{47}{Curva de degradación SNR para BCI IV 2a (modo \textit {random}). TRSS mantiene un SNR aceptable ($> 25$~dB) incluso con un 40\% de canales perdidos, mientras que las splines caen por debajo de 15~dB}{figure.caption.21}{}}
\newlabel{fig:degradation_bci_random@cref}{{[figure][4][6]6.4}{[1][36][]47}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6.5}{\ignorespaces Curva de degradación SNR para BCI IV 2a (modo \textit  {nearby}). El escenario de falla contigua es drásticamente más difícil: las splines colapsan exponencialmente, mientras que TRSS demuestra una degradación mucho más lineal y contenida.}}{47}{figure.caption.22}\protected@file@percent }
\newlabel{fig:degradation_bci_nearby}{{6.5}{47}{Curva de degradación SNR para BCI IV 2a (modo \textit {nearby}). El escenario de falla contigua es drásticamente más difícil: las splines colapsan exponencialmente, mientras que TRSS demuestra una degradación mucho más lineal y contenida}{figure.caption.22}{}}
\newlabel{fig:degradation_bci_nearby@cref}{{[figure][5][6]6.5}{[1][36][]47}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6.6}{\ignorespaces Curva de degradación para PhysioNet (64 canales, modo \textit  {nearby}). Incluso en alta densidad, la pérdida contigua genera zonas ciegas que los métodos geométricos no logran rellenar fielmente.}}{48}{figure.caption.23}\protected@file@percent }
\newlabel{fig:degradation_physionet_nearby}{{6.6}{48}{Curva de degradación para PhysioNet (64 canales, modo \textit {nearby}). Incluso en alta densidad, la pérdida contigua genera zonas ciegas que los métodos geométricos no logran rellenar fielmente}{figure.caption.23}{}}
\newlabel{fig:degradation_physionet_nearby@cref}{{[figure][6][6]6.6}{[1][37][]48}{}{}{}}
