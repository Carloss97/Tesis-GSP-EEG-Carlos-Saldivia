\@writefile{lot}{\contentsline {table}{\numberline {6.5}{\ignorespaces Complejidad computacional e implementación observada. $N$ es el número de canales, $T$ el número de muestras temporales, $E$ el número de aristas del grafo y $K$ el número de iteraciones del resolvedor.}}{40}{table.caption.28}\protected@file@percent }
