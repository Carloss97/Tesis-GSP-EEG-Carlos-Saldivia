\@writefile{toc}{\contentsline {section}{\numberline {6.1}Inventario de Evidencia Experimental}{31}{section.6.1}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {6.1}{\ignorespaces Resumen global del benchmark confirmatorio balanceado contra MNE-Python. Las métricas de error se calculan solo sobre canales artificialmente ocultos. El oráculo usa verdad de terreno para seleccionar hiperparámetros y se reporta únicamente como cota superior no desplegable.}}{32}{table.caption.17}\protected@file@percent }
\newlabel{tab:ch6_global_summary}{{6.1}{32}{Resumen global del benchmark confirmatorio balanceado contra MNE-Python. Las métricas de error se calculan solo sobre canales artificialmente ocultos. El oráculo usa verdad de terreno para seleccionar hiperparámetros y se reporta únicamente como cota superior no desplegable}{table.caption.17}{}}
\newlabel{tab:ch6_global_summary@cref}{{[table][1][6]6.1}{[1][32][]32}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6.1}{\ignorespaces Compromiso entre precisión y tiempo de cómputo en la evaluación confirmatoria. TRSS desplaza el MAE hacia valores menores, pero se ubica a la derecha de MNE en la escala logarítmica de tiempo, lo que evidencia el costo computacional de la regularización temporal.}}{32}{figure.caption.18}\protected@file@percent }
\newlabel{fig:ch6_runtime_mae_tradeoff}{{6.1}{32}{Compromiso entre precisión y tiempo de cómputo en la evaluación confirmatoria. TRSS desplaza el MAE hacia valores menores, pero se ubica a la derecha de MNE en la escala logarítmica de tiempo, lo que evidencia el costo computacional de la regularización temporal}{figure.caption.18}{}}
\newlabel{fig:ch6_runtime_mae_tradeoff@cref}{{[figure][1][6]6.1}{[1][32][]32}{}{}{}}
\@writefile{toc}{\contentsline {section}{\numberline {6.2}Comparación Pareada TRSS--MNE}{32}{section.6.2}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {6.2}{\ignorespaces Comparación robusta TRSS--MNE}}{33}{table.caption.19}\protected@file@percent }
\newlabel{tab:ch6_robust_main}{{6.2}{33}{Comparación robusta TRSS--MNE}{table.caption.19}{}}
\newlabel{tab:ch6_robust_main@cref}{{[table][2][6]6.2}{[1][33][]33}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6.2}{\ignorespaces Mejoras medianas de TRSS frente a MNE con intervalos bootstrap al 95\%. Las barras positivas favorecen a TRSS; las barras negativas favorecen a MNE o indican mayor tiempo de ejecución de TRSS. El gráfico muestra simultáneamente la ganancia en MAE/NRMSE y las dos advertencias principales: LSD y costo temporal.}}{34}{figure.caption.20}\protected@file@percent }
\newlabel{fig:ch6_robust_improvement_ci}{{6.2}{34}{Mejoras medianas de TRSS frente a MNE con intervalos bootstrap al 95\%. Las barras positivas favorecen a TRSS; las barras negativas favorecen a MNE o indican mayor tiempo de ejecución de TRSS. El gráfico muestra simultáneamente la ganancia en MAE/NRMSE y las dos advertencias principales: LSD y costo temporal}{figure.caption.20}{}}
\newlabel{fig:ch6_robust_improvement_ci@cref}{{[figure][2][6]6.2}{[1][33][]34}{}{}{}}
\@writefile{toc}{\contentsline {section}{\numberline {6.3}Estratificación por Conjunto de Datos}{34}{section.6.3}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {6.3}{\ignorespaces Estratificación por conjunto de datos para TRSS fijo frente a MNE en MAE. La ventaja no es homogénea: TRSS mejora en datos reales y en el régimen sintético rugoso, pero pierde cuando la señal sintética satisface fuertemente el supuesto de suavidad espacial.}}{34}{table.caption.21}\protected@file@percent }
\newlabel{tab:ch6_by_dataset_mae}{{6.3}{34}{Estratificación por conjunto de datos para TRSS fijo frente a MNE en MAE. La ventaja no es homogénea: TRSS mejora en datos reales y en el régimen sintético rugoso, pero pierde cuando la señal sintética satisface fuertemente el supuesto de suavidad espacial}{table.caption.21}{}}
\newlabel{tab:ch6_by_dataset_mae@cref}{{[table][3][6]6.3}{[1][34][]34}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6.3}{\ignorespaces Mejora mediana de MAE de TRSS fijo frente a MNE por conjunto de datos. La señal sintética suave actúa como control negativo: cuando se cumple fuertemente el supuesto de suavidad espacial, MNE puede ser superior.}}{35}{figure.caption.22}\protected@file@percent }
\newlabel{fig:ch6_dataset_mae_improvement}{{6.3}{35}{Mejora mediana de MAE de TRSS fijo frente a MNE por conjunto de datos. La señal sintética suave actúa como control negativo: cuando se cumple fuertemente el supuesto de suavidad espacial, MNE puede ser superior}{figure.caption.22}{}}
\newlabel{fig:ch6_dataset_mae_improvement@cref}{{[figure][3][6]6.3}{[1][34][]35}{}{}{}}
\@writefile{toc}{\contentsline {section}{\numberline {6.4}Efecto del Patrón y Severidad de Pérdida}{36}{section.6.4}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {6.4}{\ignorespaces Escenarios representativos para TRSS fijo frente a MNE en MAE. La mejora aumenta en pérdidas clusterizadas o periféricas de alta severidad, mientras que escenarios de pocos canales cercanos pueden producir empate práctico.}}{36}{table.caption.23}\protected@file@percent }
\newlabel{tab:ch6_selected_scenarios_mae}{{6.4}{36}{Escenarios representativos para TRSS fijo frente a MNE en MAE. La mejora aumenta en pérdidas clusterizadas o periféricas de alta severidad, mientras que escenarios de pocos canales cercanos pueden producir empate práctico}{table.caption.23}{}}
\newlabel{tab:ch6_selected_scenarios_mae@cref}{{[table][4][6]6.4}{[1][36][]36}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6.4}{\ignorespaces Mapa de calor de mejora mediana de MAE para TRSS fijo frente a MNE. Cada celda muestra la mejora mediana y, debajo, la tasa de victoria. La ventaja crece cuando la pérdida elimina información espacial local, especialmente en patrones cercanos o periféricos de alta severidad.}}{36}{figure.caption.24}\protected@file@percent }
\newlabel{fig:ch6_scenario_heatmap_mae}{{6.4}{36}{Mapa de calor de mejora mediana de MAE para TRSS fijo frente a MNE. Cada celda muestra la mejora mediana y, debajo, la tasa de victoria. La ventaja crece cuando la pérdida elimina información espacial local, especialmente en patrones cercanos o periféricos de alta severidad}{figure.caption.24}{}}
\newlabel{fig:ch6_scenario_heatmap_mae@cref}{{[figure][4][6]6.4}{[1][36][]36}{}{}{}}
\@writefile{toc}{\contentsline {section}{\numberline {6.5}Ablación del Término Temporal}{37}{section.6.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6.5}{\ignorespaces Ablación del componente temporal: mejora mediana de TRSS completo frente a TRSS sin término temporal. La contribución temporal es consistente dentro de la familia TRSS, aunque su magnitud es menor que las diferencias entre familias de métodos.}}{37}{figure.caption.25}\protected@file@percent }
\newlabel{fig:ch6_ablation_temporal_component}{{6.5}{37}{Ablación del componente temporal: mejora mediana de TRSS completo frente a TRSS sin término temporal. La contribución temporal es consistente dentro de la familia TRSS, aunque su magnitud es menor que las diferencias entre familias de métodos}{figure.caption.25}{}}
\newlabel{fig:ch6_ablation_temporal_component@cref}{{[figure][5][6]6.5}{[1][37][]37}{}{}{}}
\@writefile{toc}{\contentsline {section}{\numberline {6.6}Preservación Morfológica y Espectral}{38}{section.6.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6.6}{\ignorespaces Ejemplo cualitativo de reconstrucción temporal bajo pérdida cercana severa. La figura ilustra la diferencia morfológica que las métricas agregadas capturan de forma resumida.}}{38}{figure.caption.26}\protected@file@percent }
\newlabel{fig:ch6_erp_severo}{{6.6}{38}{Ejemplo cualitativo de reconstrucción temporal bajo pérdida cercana severa. La figura ilustra la diferencia morfológica que las métricas agregadas capturan de forma resumida}{figure.caption.26}{}}
\newlabel{fig:ch6_erp_severo@cref}{{[figure][6][6]6.6}{[1][38][]38}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6.7}{\ignorespaces Comparación espectral multi-método. La preservación de potencia por banda no siempre coincide con la mejora de MAE, por lo que LSD se reporta como dimensión independiente y no como consecuencia automática del error de amplitud.}}{39}{figure.caption.27}\protected@file@percent }
\newlabel{fig:ch6_psd_comparison}{{6.7}{39}{Comparación espectral multi-método. La preservación de potencia por banda no siempre coincide con la mejora de MAE, por lo que LSD se reporta como dimensión independiente y no como consecuencia automática del error de amplitud}{figure.caption.27}{}}
\newlabel{fig:ch6_psd_comparison@cref}{{[figure][7][6]6.7}{[1][39][]39}{}{}{}}
