\@writefile{toc}{\contentsline {section}{\numberline {4.6}Resumen descriptivo de TRSS frente a MNE}{35}{section.4.6}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4.6}{\ignorespaces Resumen descriptivo pareado de TRSS fijo frente a MNE. La mejora mediana positiva favorece a TRSS después de respetar la dirección de cada métrica. La tasa de victoria indica la proporción de pares donde TRSS supera a MNE. Los intervalos son bootstrap descriptivos al 95\%, no pruebas de hipótesis.}}{35}{table.caption.25}\protected@file@percent }
\newlabel{tab:ch4_descriptive_trss_mne}{{4.6}{35}{Resumen descriptivo pareado de TRSS fijo frente a MNE. La mejora mediana positiva favorece a TRSS después de respetar la dirección de cada métrica. La tasa de victoria indica la proporción de pares donde TRSS supera a MNE. Los intervalos son bootstrap descriptivos al 95\%, no pruebas de hipótesis}{table.caption.25}{}}
\newlabel{tab:ch4_descriptive_trss_mne@cref}{{[table][6][4]4.6}{[1][35][]35}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.1}{\ignorespaces Perfil descriptivo de calidad para TRSS fijo frente a MNE. Las barras positivas favorecen a TRSS después de respetar la dirección de cada métrica; las barras negativas favorecen a MNE. El costo temporal se reporta por separado porque su escala es muy distinta a la de las métricas de reconstrucción.}}{36}{figure.caption.26}\protected@file@percent }
\newlabel{fig:ch4_metric_profile_descriptive}{{4.1}{36}{Perfil descriptivo de calidad para TRSS fijo frente a MNE. Las barras positivas favorecen a TRSS después de respetar la dirección de cada métrica; las barras negativas favorecen a MNE. El costo temporal se reporta por separado porque su escala es muy distinta a la de las métricas de reconstrucción}{figure.caption.26}{}}
\newlabel{fig:ch4_metric_profile_descriptive@cref}{{[figure][1][4]4.1}{[1][35][]36}{}{}{}}
\@writefile{toc}{\contentsline {section}{\numberline {4.7}Dependencia respecto del escenario de pérdida}{36}{section.4.7}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4.7}{\ignorespaces Resumen por patrón y severidad de pérdida para MAE. Cada fila reporta la mejora mediana de TRSS frente a MNE, la tasa de victoria (proporción de pares donde TRSS obtiene menor MAE) y la mejora media como lectura complementaria.}}{36}{table.caption.27}\protected@file@percent }
\newlabel{tab:ch4_scenario_summary_descriptive}{{4.7}{36}{Resumen por patrón y severidad de pérdida para MAE. Cada fila reporta la mejora mediana de TRSS frente a MNE, la tasa de victoria (proporción de pares donde TRSS obtiene menor MAE) y la mejora media como lectura complementaria}{table.caption.27}{}}
\newlabel{tab:ch4_scenario_summary_descriptive@cref}{{[table][7][4]4.7}{[1][36][]36}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.2}{\ignorespaces Resumen por patrón y severidad de pérdida. Cada celda muestra mejora mediana de MAE, tasa de victoria (WR) y número de pares. La ventaja de TRSS crece en pérdidas cercanas o periféricas severas, donde la información espacial local disponible para MNE disminuye.}}{37}{figure.caption.28}\protected@file@percent }
\newlabel{fig:ch4_scenario_summary_descriptive}{{4.2}{37}{Resumen por patrón y severidad de pérdida. Cada celda muestra mejora mediana de MAE, tasa de victoria (WR) y número de pares. La ventaja de TRSS crece en pérdidas cercanas o periféricas severas, donde la información espacial local disponible para MNE disminuye}{figure.caption.28}{}}
\newlabel{fig:ch4_scenario_summary_descriptive@cref}{{[figure][2][4]4.2}{[1][37][]37}{}{}{}}
\@writefile{toc}{\contentsline {section}{\numberline {4.8}Reconstrucciones temporales representativas}{37}{section.4.8}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4.8}{\ignorespaces Casos representativos seleccionados de forma reproducible para inspección temporal y espectral. La mejora se calcula en MAE para TRSS fijo frente a MNE; valores negativos indican que MNE fue mejor en ese caso.}}{38}{table.caption.29}\protected@file@percent }
\newlabel{tab:ch4_representative_cases}{{4.8}{38}{Casos representativos seleccionados de forma reproducible para inspección temporal y espectral. La mejora se calcula en MAE para TRSS fijo frente a MNE; valores negativos indican que MNE fue mejor en ese caso}{table.caption.29}{}}
\newlabel{tab:ch4_representative_cases@cref}{{[table][8][4]4.8}{[1][37][]38}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.3}{\ignorespaces Reconstrucciones temporales representativas en MNE Sample. Cada fila muestra señal original, reconstrucción MNE y reconstrucción TRSS para un canal oculto seleccionado de forma reproducible. Los casos incluyen un escenario favorable a TRSS, uno favorable a MNE, un empate práctico y una pérdida cercana severa.}}{39}{figure.caption.30}\protected@file@percent }
\newlabel{fig:ch4_representative_timeseries}{{4.3}{39}{Reconstrucciones temporales representativas en MNE Sample. Cada fila muestra señal original, reconstrucción MNE y reconstrucción TRSS para un canal oculto seleccionado de forma reproducible. Los casos incluyen un escenario favorable a TRSS, uno favorable a MNE, un empate práctico y una pérdida cercana severa}{figure.caption.30}{}}
\newlabel{fig:ch4_representative_timeseries@cref}{{[figure][3][4]4.3}{[1][38][]39}{}{}{}}
\@writefile{toc}{\contentsline {section}{\numberline {4.9}Preservación espectral de las señales reconstruidas}{39}{section.4.9}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.4}{\ignorespaces PSD original versus PSD interpolado para los casos representativos. La figura compara directamente la densidad espectral de potencia de la señal original con las reconstrucciones MNE y TRSS. Esta lectura permite explicar por qué TRSS puede mejorar error de amplitud sin dominar necesariamente la métrica LSD.}}{40}{figure.caption.31}\protected@file@percent }
\newlabel{fig:ch4_psd_original_vs_interpolated}{{4.4}{40}{PSD original versus PSD interpolado para los casos representativos. La figura compara directamente la densidad espectral de potencia de la señal original con las reconstrucciones MNE y TRSS. Esta lectura permite explicar por qué TRSS puede mejorar error de amplitud sin dominar necesariamente la métrica LSD}{figure.caption.31}{}}
\newlabel{fig:ch4_psd_original_vs_interpolated@cref}{{[figure][4][4]4.4}{[1][39][]40}{}{}{}}
