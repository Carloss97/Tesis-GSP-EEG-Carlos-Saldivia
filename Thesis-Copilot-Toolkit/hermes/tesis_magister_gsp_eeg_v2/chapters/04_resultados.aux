\@writefile{lot}{\contentsline {table}{\numberline {4.6}{\ignorespaces Contribución descriptiva del término temporal dentro de TRSS. La comparación retira el término temporal y mide cuánto cambia el desempeño relativo del modelo completo.}}{41}{table.caption.30}\protected@file@percent }
\newlabel{tab:ch4_temporal_component_summary}{{4.6}{41}{Contribución descriptiva del término temporal dentro de TRSS. La comparación retira el término temporal y mide cuánto cambia el desempeño relativo del modelo completo}{table.caption.30}{}}
