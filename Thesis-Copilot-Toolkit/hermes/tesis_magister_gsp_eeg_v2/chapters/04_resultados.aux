\@writefile{toc}{\contentsline {section}{\numberline {4.6}Resumen descriptivo de TRSS frente a MNE}{34}{section.4.6}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4.3}{\ignorespaces Resumen descriptivo pareado de TRSS fijo frente a MNE para métricas de calidad. La mejora mediana positiva favorece a TRSS después de respetar la dirección de cada métrica; la tasa de victoria indica la proporción de pares donde TRSS supera a MNE. Los intervalos son bootstrap descriptivos al 95\%.}}{34}{table.caption.23}\protected@file@percent }
\newlabel{tab:ch4_descriptive_trss_mne}{{4.3}{34}{Resumen descriptivo pareado de TRSS fijo frente a MNE para métricas de calidad. La mejora mediana positiva favorece a TRSS después de respetar la dirección de cada métrica; la tasa de victoria indica la proporción de pares donde TRSS supera a MNE. Los intervalos son bootstrap descriptivos al 95\%}{table.caption.23}{}}
\newlabel{tab:ch4_descriptive_trss_mne@cref}{{[table][3][4]4.3}{[1][34][]34}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.2}{\ignorespaces Perfil descriptivo de calidad para TRSS fijo frente a MNE. Las barras positivas favorecen a TRSS después de respetar la dirección de cada métrica; las barras negativas favorecen a MNE. El costo temporal se reporta por separado porque su escala es muy distinta a la de las métricas de reconstrucción.}}{35}{figure.caption.24}\protected@file@percent }
\newlabel{fig:ch4_metric_profile_descriptive}{{4.2}{35}{Perfil descriptivo de calidad para TRSS fijo frente a MNE. Las barras positivas favorecen a TRSS después de respetar la dirección de cada métrica; las barras negativas favorecen a MNE. El costo temporal se reporta por separado porque su escala es muy distinta a la de las métricas de reconstrucción}{figure.caption.24}{}}
\newlabel{fig:ch4_metric_profile_descriptive@cref}{{[figure][2][4]4.2}{[1][34][]35}{}{}{}}
\@writefile{toc}{\contentsline {section}{\numberline {4.7}Efecto del escenario de pérdida}{35}{section.4.7}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4.4}{\ignorespaces Resumen por patrón y severidad de pérdida para MAE. Cada fila reporta la mejora mediana de TRSS frente a MNE, la tasa de victoria (proporción de pares donde TRSS obtiene menor MAE) y la mejora media como lectura complementaria.}}{35}{table.caption.25}\protected@file@percent }
\newlabel{tab:ch4_scenario_summary_descriptive}{{4.4}{35}{Resumen por patrón y severidad de pérdida para MAE. Cada fila reporta la mejora mediana de TRSS frente a MNE, la tasa de victoria (proporción de pares donde TRSS obtiene menor MAE) y la mejora media como lectura complementaria}{table.caption.25}{}}
\newlabel{tab:ch4_scenario_summary_descriptive@cref}{{[table][4][4]4.4}{[1][35][]35}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.3}{\ignorespaces Resumen por patrón y severidad de pérdida. Cada celda muestra mejora mediana de MAE, tasa de victoria (WR) y número de pares. La ventaja de TRSS crece en pérdidas cercanas o periféricas severas, donde la información espacial local disponible para MNE disminuye.}}{36}{figure.caption.26}\protected@file@percent }
\newlabel{fig:ch4_scenario_summary_descriptive}{{4.3}{36}{Resumen por patrón y severidad de pérdida. Cada celda muestra mejora mediana de MAE, tasa de victoria (WR) y número de pares. La ventaja de TRSS crece en pérdidas cercanas o periféricas severas, donde la información espacial local disponible para MNE disminuye}{figure.caption.26}{}}
\newlabel{fig:ch4_scenario_summary_descriptive@cref}{{[figure][3][4]4.3}{[1][36][]36}{}{}{}}
\@writefile{toc}{\contentsline {section}{\numberline {4.8}Señales temporales representativas}{36}{section.4.8}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4.5}{\ignorespaces Casos representativos seleccionados de forma reproducible en MNE Sample para inspección temporal y espectral. La mejora se calcula en MAE para TRSS fijo frente a MNE; valores negativos indican que MNE fue mejor en ese caso.}}{37}{table.caption.27}\protected@file@percent }
\newlabel{tab:ch4_representative_cases}{{4.5}{37}{Casos representativos seleccionados de forma reproducible en MNE Sample para inspección temporal y espectral. La mejora se calcula en MAE para TRSS fijo frente a MNE; valores negativos indican que MNE fue mejor en ese caso}{table.caption.27}{}}
\newlabel{tab:ch4_representative_cases@cref}{{[table][5][4]4.5}{[1][36][]37}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.4}{\ignorespaces Reconstrucciones temporales representativas en MNE Sample. Cada fila muestra señal original, reconstrucción MNE y reconstrucción TRSS para un canal oculto seleccionado de forma reproducible. Los casos incluyen un escenario favorable a TRSS, uno favorable a MNE, un empate práctico y una pérdida cercana severa.}}{38}{figure.caption.28}\protected@file@percent }
\newlabel{fig:ch4_representative_timeseries}{{4.4}{38}{Reconstrucciones temporales representativas en MNE Sample. Cada fila muestra señal original, reconstrucción MNE y reconstrucción TRSS para un canal oculto seleccionado de forma reproducible. Los casos incluyen un escenario favorable a TRSS, uno favorable a MNE, un empate práctico y una pérdida cercana severa}{figure.caption.28}{}}
\newlabel{fig:ch4_representative_timeseries@cref}{{[figure][4][4]4.4}{[1][37][]38}{}{}{}}
\@writefile{toc}{\contentsline {section}{\numberline {4.9}Preservación espectral}{38}{section.4.9}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.5}{\ignorespaces PSD original versus PSD interpolado para los casos representativos. La figura compara directamente la densidad espectral de potencia de la señal original con las reconstrucciones MNE y TRSS. Esta lectura permite explicar por qué TRSS puede mejorar error de amplitud sin dominar necesariamente la métrica LSD.}}{39}{figure.caption.29}\protected@file@percent }
\newlabel{fig:ch4_psd_original_vs_interpolated}{{4.5}{39}{PSD original versus PSD interpolado para los casos representativos. La figura compara directamente la densidad espectral de potencia de la señal original con las reconstrucciones MNE y TRSS. Esta lectura permite explicar por qué TRSS puede mejorar error de amplitud sin dominar necesariamente la métrica LSD}{figure.caption.29}{}}
\newlabel{fig:ch4_psd_original_vs_interpolated@cref}{{[figure][5][4]4.5}{[1][38][]39}{}{}{}}
