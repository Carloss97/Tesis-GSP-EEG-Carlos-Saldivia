\newlabel{fig:ch4_temporal_component_contribution}{{4.6}{41}{Aporte descriptivo del término temporal dentro de TRSS. Las barras muestran la mejora de TRSS completo frente a TRSS sin término temporal}{figure.caption.31}{}}
\newlabel{fig:ch4_temporal_component_contribution@cref}{{[figure][6][4]4.6}{[1][41][]41}{}{}{}}
