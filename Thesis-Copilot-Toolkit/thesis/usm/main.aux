\newlabel{fig:tradeoff_scatter}{{4.12}{36}{Frontera de Pareto MAE vs. DTW para MNE Sample. TRSS domina ambas dimensiones simultáneamente, posicionándose en la esquina inferior izquierda (mínimo error, mínima distorsión temporal)}{figure.caption.23}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.13}{\ignorespaces Frontera de Pareto para BCI IV 2a. Los baselines geométricos forman un cluster alejado del origen, evidenciando un compromiso inherente entre precisión y fidelidad temporal que TRSS evita completamente.}}{37}{figure.caption.24}\protected@file@percent }
\newlabel{fig:tradeoff_bci}{{4.13}{37}{Frontera de Pareto para BCI IV 2a. Los baselines geométricos forman un cluster alejado del origen, evidenciando un compromiso inherente entre precisión y fidelidad temporal que TRSS evita completamente}{figure.caption.24}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.14}{\ignorespaces Reconstrucción de ERP en MNE Sample con 10\% de pérdida \textit  {nearby}. En este escenario benigno, tanto TRSS como los baselines logran una reconstrucción razonable, aunque ya se observan desfases sutiles en las splines.}}{38}{figure.caption.25}\protected@file@percent }
\newlabel{fig:erp_10pct}{{4.14}{38}{Reconstrucción de ERP en MNE Sample con 10\% de pérdida \textit {nearby}. En este escenario benigno, tanto TRSS como los baselines logran una reconstrucción razonable, aunque ya se observan desfases sutiles en las splines}{figure.caption.25}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.15}{\ignorespaces Reconstrucción de ERP en MNE Sample con 40\% de pérdida \textit  {nearby}. Bajo degradación severa, las splines esféricas colapsan completamente: la amplitud del P300 se aplana y la fase se invierte. TRSS preserva fielmente la trayectoria fisiológica original.}}{39}{figure.caption.26}\protected@file@percent }
\newlabel{fig:erp_40pct}{{4.15}{39}{Reconstrucción de ERP en MNE Sample con 40\% de pérdida \textit {nearby}. Bajo degradación severa, las splines esféricas colapsan completamente: la amplitud del P300 se aplana y la fase se invierte. TRSS preserva fielmente la trayectoria fisiológica original}{figure.caption.26}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.16}{\ignorespaces Reconstrucción de ERP con baselines optimizados por Optuna (1 canal faltante \textit  {nearby}). Incluso en el escenario más benigno posible, TRSS logra una traza más fiel a la señal original.}}{40}{figure.caption.27}\protected@file@percent }
\newlabel{fig:erp_baselines_optimized}{{4.16}{40}{Reconstrucción de ERP con baselines optimizados por Optuna (1 canal faltante \textit {nearby}). Incluso en el escenario más benigno posible, TRSS logra una traza más fiel a la señal original}{figure.caption.27}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.17}{\ignorespaces Reconstrucción de ERP con baselines optimizados (40\% \textit  {nearby}). La optimización de hiperparámetros de las splines no previene su colapso ante degradación severa. TRSS mantiene la trayectoria correcta.}}{40}{figure.caption.28}\protected@file@percent }
\newlabel{fig:erp_baselines_severe}{{4.17}{40}{Reconstrucción de ERP con baselines optimizados (40\% \textit {nearby}). La optimización de hiperparámetros de las splines no previene su colapso ante degradación severa. TRSS mantiene la trayectoria correcta}{figure.caption.28}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.18}{\ignorespaces Comparación de PSD entre señal original, TRSS y baselines. TRSS reproduce fielmente el perfil espectral completo, preservando los picos en las bandas Alfa y Beta.}}{41}{figure.caption.29}\protected@file@percent }
\newlabel{fig:psd_best}{{4.18}{41}{Comparación de PSD entre señal original, TRSS y baselines. TRSS reproduce fielmente el perfil espectral completo, preservando los picos en las bandas Alfa y Beta}{figure.caption.29}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.19}{\ignorespaces PSD con baselines optimizados (1 canal faltante). Los métodos geométricos introducen distorsiones espectrales a altas frecuencias (banda Beta y Gamma), mientras que TRSS preserva la distribución.}}{42}{figure.caption.30}\protected@file@percent }
\newlabel{fig:psd_baselines}{{4.19}{42}{PSD con baselines optimizados (1 canal faltante). Los métodos geométricos introducen distorsiones espectrales a altas frecuencias (banda Beta y Gamma), mientras que TRSS preserva la distribución}{figure.caption.30}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.20}{\ignorespaces PSD bajo condiciones extremas de pérdida de canales. Las distorsiones espectrales de los métodos geométricos se amplifican dramáticamente, particularmente en las bandas de alta frecuencia.}}{43}{figure.caption.31}\protected@file@percent }
\newlabel{fig:psd_extreme}{{4.20}{43}{PSD bajo condiciones extremas de pérdida de canales. Las distorsiones espectrales de los métodos geométricos se amplifican dramáticamente, particularmente en las bandas de alta frecuencia}{figure.caption.31}{}}
