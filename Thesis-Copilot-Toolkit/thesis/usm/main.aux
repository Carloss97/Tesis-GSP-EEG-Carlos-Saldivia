\@writefile{lof}{\contentsline {figure}{\numberline {4.10}{\ignorespaces Heatmap de RMSE para PhysioNet. La alta densidad de canales suaviza las diferencias en escenarios benignos, pero la dominancia de TRSS emerge claramente en las columnas de alta degradación.}}{41}{figure.caption.23}\protected@file@percent }
\newlabel{fig:heatmap_physionet}{{4.10}{41}{Heatmap de RMSE para PhysioNet. La alta densidad de canales suaviza las diferencias en escenarios benignos, pero la dominancia de TRSS emerge claramente en las columnas de alta degradación}{figure.caption.23}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.11}{\ignorespaces Frontera de Pareto MAE vs. DTW para MNE Sample. TRSS domina ambas dimensiones simultáneamente, posicionándose en la esquina inferior izquierda (mínimo error, mínima distorsión temporal).}}{42}{figure.caption.25}\protected@file@percent }
\newlabel{fig:tradeoff_scatter}{{4.11}{42}{Frontera de Pareto MAE vs. DTW para MNE Sample. TRSS domina ambas dimensiones simultáneamente, posicionándose en la esquina inferior izquierda (mínimo error, mínima distorsión temporal)}{figure.caption.25}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.12}{\ignorespaces Frontera de Pareto para BCI IV 2a. Los baselines geométricos forman un cluster alejado del origen, evidenciando un compromiso inherente entre precisión y fidelidad temporal que TRSS evita completamente.}}{43}{figure.caption.26}\protected@file@percent }
\newlabel{fig:tradeoff_bci}{{4.12}{43}{Frontera de Pareto para BCI IV 2a. Los baselines geométricos forman un cluster alejado del origen, evidenciando un compromiso inherente entre precisión y fidelidad temporal que TRSS evita completamente}{figure.caption.26}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.13}{\ignorespaces 10\% de pérdida \textit  {nearby}. MNE y Spline logran buena reconstrucción por la alta densidad, aunque ICA lanza picos distorsionados.}}{44}{figure.caption.27}\protected@file@percent }
\newlabel{fig:erp_10pct}{{4.13}{44}{10\% de pérdida \textit {nearby}. MNE y Spline logran buena reconstrucción por la alta densidad, aunque ICA lanza picos distorsionados}{figure.caption.27}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.14}{\ignorespaces 40\% de pérdida \textit  {nearby}. Bajo degradación masiva, las splines y MNE colapsan invirtiendo fase. TRSS resiste mediante inercia.}}{44}{figure.caption.27}\protected@file@percent }
\newlabel{fig:erp_40pct}{{4.14}{44}{40\% de pérdida \textit {nearby}. Bajo degradación masiva, las splines y MNE colapsan invirtiendo fase. TRSS resiste mediante inercia}{figure.caption.27}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.15}{\ignorespaces Comparación de reconstrucción de ERP (1 canal) bajo distinta severidad de pérdida. Ambos ejes Y están fijados al rango de la señal original para evidenciar las distorsiones de amplitud introducidas por los baselines geométricos.}}{44}{figure.caption.27}\protected@file@percent }
\newlabel{fig:erp_sidebyside}{{4.15}{44}{Comparación de reconstrucción de ERP (1 canal) bajo distinta severidad de pérdida. Ambos ejes Y están fijados al rango de la señal original para evidenciar las distorsiones de amplitud introducidas por los baselines geométricos}{figure.caption.27}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.16}{\ignorespaces Reconstrucción de ERP con baselines optimizados por Optuna (1 canal faltante \textit  {nearby}). Incluso en el escenario más benigno posible, TRSS logra una traza más fiel a la señal original.}}{44}{figure.caption.28}\protected@file@percent }
\newlabel{fig:erp_baselines_optimized}{{4.16}{44}{Reconstrucción de ERP con baselines optimizados por Optuna (1 canal faltante \textit {nearby}). Incluso en el escenario más benigno posible, TRSS logra una traza más fiel a la señal original}{figure.caption.28}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.17}{\ignorespaces Reconstrucción de ERP con baselines optimizados (40\% \textit  {nearby}). La optimización de hiperparámetros de las splines no previene su colapso ante degradación severa. TRSS mantiene la trayectoria correcta.}}{45}{figure.caption.29}\protected@file@percent }
\newlabel{fig:erp_baselines_severe}{{4.17}{45}{Reconstrucción de ERP con baselines optimizados (40\% \textit {nearby}). La optimización de hiperparámetros de las splines no previene su colapso ante degradación severa. TRSS mantiene la trayectoria correcta}{figure.caption.29}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.18}{\ignorespaces Comparación de PSD entre señal original, TRSS y baselines. TRSS reproduce fielmente el perfil espectral completo, preservando los picos en las bandas Alfa y Beta.}}{45}{figure.caption.30}\protected@file@percent }
\newlabel{fig:psd_best}{{4.18}{45}{Comparación de PSD entre señal original, TRSS y baselines. TRSS reproduce fielmente el perfil espectral completo, preservando los picos en las bandas Alfa y Beta}{figure.caption.30}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.19}{\ignorespaces PSD con baselines optimizados (1 canal faltante). Los métodos geométricos introducen distorsiones espectrales a altas frecuencias (banda Beta y Gamma), mientras que TRSS preserva la distribución.}}{46}{figure.caption.31}\protected@file@percent }
\newlabel{fig:psd_baselines}{{4.19}{46}{PSD con baselines optimizados (1 canal faltante). Los métodos geométricos introducen distorsiones espectrales a altas frecuencias (banda Beta y Gamma), mientras que TRSS preserva la distribución}{figure.caption.31}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.20}{\ignorespaces PSD bajo condiciones extremas de pérdida de canales. Las distorsiones espectrales de los métodos geométricos se amplifican dramáticamente, particularmente en las bandas de alta frecuencia.}}{47}{figure.caption.32}\protected@file@percent }
\newlabel{fig:psd_extreme}{{4.20}{47}{PSD bajo condiciones extremas de pérdida de canales. Las distorsiones espectrales de los métodos geométricos se amplifican dramáticamente, particularmente en las bandas de alta frecuencia}{figure.caption.32}{}}
