\contentsline {figure}{\numberline {3.1}{\ignorespaces Representación esquemática del pipeline metodológico de optimización y evaluación propuesto.}}{14}{figure.caption.8}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {4.1}{\ignorespaces Comparación de rendimiento global en PhysioNet (64 canales). TRSS y Tikhonov dominan todas las métricas tras optimización con Optuna. El eje vertical muestra el MAE promedio optimizado.}}{27}{figure.caption.13}%
\contentsline {figure}{\numberline {4.2}{\ignorespaces Radar multi-métrica para BCI IV 2a bajo 40\% de pérdida \textit {nearby}. El escenario más adverso para un dataset de baja densidad (22 canales). TRSS mantiene la superioridad incluso cuando la malla sensora pierde casi la mitad de su cobertura en una región contigua.}}{35}{figure.caption.15}%
\contentsline {figure}{\numberline {4.3}{\ignorespaces Radar multi-métrica para PhysioNet bajo 40\% de pérdida aleatoria. La alta densidad de electrodos (64 canales) favorece a todos los métodos, pero TRSS mantiene una ventaja clara en DTW y LSD.}}{36}{figure.caption.16}%
\contentsline {figure}{\numberline {4.4}{\ignorespaces Curva de degradación SNR para BCI IV 2a (modo \textit {random}). TRSS mantiene un SNR aceptable ($> 25$~dB) incluso con un 40\% de canales perdidos, mientras que las splines caen por debajo de 15~dB.}}{37}{figure.caption.17}%
\contentsline {figure}{\numberline {4.5}{\ignorespaces Curva de degradación SNR para BCI IV 2a (modo \textit {nearby}). El escenario de falla contigua es drásticamente más difícil: las splines colapsan exponencialmente, mientras que TRSS demuestra una degradación mucho más lineal y contenida.}}{37}{figure.caption.18}%
\contentsline {figure}{\numberline {4.6}{\ignorespaces Curva de degradación para PhysioNet (64 canales, modo \textit {nearby}). Incluso en alta densidad, la pérdida contigua genera zonas ciegas que los métodos geométricos no logran rellenar fielmente.}}{38}{figure.caption.19}%
\contentsline {figure}{\numberline {4.7}{\ignorespaces Curva de degradación para MNE Sample (60 canales, modo \textit {nearby}). La caída abrupta de las splines a partir del 20\% contrasta con la estabilidad de TRSS.}}{38}{figure.caption.20}%
\contentsline {figure}{\numberline {4.8}{\ignorespaces Heatmap de RMSE para MNE Sample. Cada fila es un método; cada columna una combinación de modo/nivel. Los tonos oscuros (menor error) se concentran en TRSS y Tikhonov de forma consistente.}}{39}{figure.caption.21}%
\contentsline {figure}{\numberline {4.9}{\ignorespaces Heatmap de RMSE para BCI IV 2a. Las columnas de alta degradación \textit {nearby} exhiben un contraste cromático dramático entre las familias temporal y geométrica.}}{40}{figure.caption.22}%
\contentsline {figure}{\numberline {4.10}{\ignorespaces Heatmap de RMSE para PhysioNet. La alta densidad de canales suaviza las diferencias en escenarios benignos, pero la dominancia de TRSS emerge claramente en las columnas de alta degradación.}}{41}{figure.caption.23}%
\contentsline {figure}{\numberline {4.11}{\ignorespaces Frontera de Pareto MAE vs. DTW para MNE Sample. TRSS domina ambas dimensiones simultáneamente, posicionándose en la esquina inferior izquierda (mínimo error, mínima distorsión temporal).}}{42}{figure.caption.25}%
\contentsline {figure}{\numberline {4.12}{\ignorespaces Frontera de Pareto para BCI IV 2a. Los baselines geométricos forman un cluster alejado del origen, evidenciando un compromiso inherente entre precisión y fidelidad temporal que TRSS evita completamente.}}{43}{figure.caption.26}%
\contentsline {figure}{\numberline {4.13}{\ignorespaces 10\% de pérdida \textit {nearby}. MNE y Spline logran buena reconstrucción por la alta densidad, aunque ICA lanza picos distorsionados.}}{44}{figure.caption.27}%
\contentsline {figure}{\numberline {4.14}{\ignorespaces 40\% de pérdida \textit {nearby}. Bajo degradación masiva, las splines y MNE colapsan invirtiendo fase. TRSS resiste mediante inercia.}}{44}{figure.caption.27}%
\contentsline {figure}{\numberline {4.15}{\ignorespaces Comparación de reconstrucción de ERP (1 canal) bajo distinta severidad de pérdida. Ambos ejes Y están fijados al rango de la señal original para evidenciar las distorsiones de amplitud introducidas por los baselines geométricos.}}{44}{figure.caption.27}%
\contentsline {figure}{\numberline {4.16}{\ignorespaces Reconstrucción de ERP con baselines optimizados por Optuna (1 canal faltante \textit {nearby}). Incluso en el escenario más benigno posible, TRSS logra una traza más fiel a la señal original.}}{44}{figure.caption.28}%
\contentsline {figure}{\numberline {4.17}{\ignorespaces Reconstrucción de ERP con baselines optimizados (40\% \textit {nearby}). La optimización de hiperparámetros de las splines no previene su colapso ante degradación severa. TRSS mantiene la trayectoria correcta.}}{45}{figure.caption.29}%
\contentsline {figure}{\numberline {4.18}{\ignorespaces Comparación de PSD entre señal original, TRSS y baselines. TRSS reproduce fielmente el perfil espectral completo, preservando los picos en las bandas Alfa y Beta.}}{45}{figure.caption.30}%
\contentsline {figure}{\numberline {4.19}{\ignorespaces PSD con baselines optimizados (1 canal faltante). Los métodos geométricos introducen distorsiones espectrales a altas frecuencias (banda Beta y Gamma), mientras que TRSS preserva la distribución.}}{46}{figure.caption.31}%
\contentsline {figure}{\numberline {4.20}{\ignorespaces PSD bajo condiciones extremas de pérdida de canales. Las distorsiones espectrales de los métodos geométricos se amplifican dramáticamente, particularmente en las bandas de alta frecuencia.}}{47}{figure.caption.32}%
