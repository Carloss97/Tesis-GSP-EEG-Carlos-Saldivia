q
210 36 80 80 re W n
[ 78.02002 0 0 -78.215552 210.996143 115.028679 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 399
  /Height 400
  /Interpolate true
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 399 0 0 -400 0 400 ]
