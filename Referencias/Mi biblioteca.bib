	note = {{ISSN}: 2379-190X},
	keywords = {Dictionaries, Signal reconstruction, Speech processing, Accuracy, Energy measurement, generalized graph signal reconstruction, joint vertex-time dictionary, localized representation, Location awareness, Noise robustness, Social networking (online), Time-frequency analysis, Uncertainty, Uncertainty principle},
	file = {Full Text PDF:C\:\\Users\\sarlo\\Zotero\\storage\\LRYEWZ7B\\Zhao et al. - 2025 - Generalized Graph Signal Reconstruction via the Uncertainty Principle.pdf:application/pdf},
