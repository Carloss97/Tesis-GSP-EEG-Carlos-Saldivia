	date = {2020-05},
	note = {{ISSN}: 2379-190X},
	keywords = {graph, Graph construction, Graph learning, Kernel, {KNN} graph, {LLE} Graph, Manifolds, Neighborhood graph, Robustness, Signal processing, Speech processing, Supervised learning, Task analysis},
	file = {Full Text PDF:C\:\\Users\\sarlo\\Zotero\\storage\\5IHABJNC\\Shekkizhar y Ortega - 2020 - Graph Construction from Data by Non-Negative Kernel Regression.pdf:application/pdf;IEEE Xplore Abstract Record:C\:\\Users\\sarlo\\Zotero\\storage\\MN6NLXWH\\9054425.html:text/html},
