	note = {{ISSN}: 2076-1465},
	keywords = {Electroencephalography, Signal processing, Delay effects, Delays, Dynamic Graphs, Europe, Graph Signal Processing, Signal processing algorithms, Synchronization, Temporal Graphs, Time Varying Graphs, Visibility Graphs},
	file = {Full Text PDF:C\:\\Users\\sarlo\\Zotero\\storage\\FGIICQH3\\Bozkurt y Ortega - 2022 - Non-Negative Kernel Graphs for Time-Varying Signals Using Visibility Graphs.pdf:application/pdf;IEEE Xplore Abstract Record:C\:\\Users\\sarlo\\Zotero\\storage\\ZDPU4VPL\\9909594.html:text/html},
